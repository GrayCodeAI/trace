root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Go uses tabs.
[*.go]
indent_style = tab
indent_size = 4

# Makefile-likes use tabs by language convention.
[{Makefile,*.mk,**.mk}]
indent_style = tab
indent_size = 4

# Shell scripts: 2 spaces matches POSIX convention used in scripts/ and mise-tasks/.
[*.{sh,bash,zsh}]
indent_style = space
indent_size = 2

# YAML / JSON / TOML: 2 spaces.
[*.{yml,yaml,json,toml}]
indent_style = space
indent_size = 2

# Markdown: trailing whitespace is sometimes significant (line break with two spaces).
[*.md]
trim_trailing_whitespace = false
