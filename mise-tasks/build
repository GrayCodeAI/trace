#!/bin/sh
#MISE description="Build the CLI"

TAG=$(git describe --tags --abbrev=0 || echo "v0.0.0")
COMMIT=$(git rev-parse --short HEAD 2>/dev/null || echo "unknown")
VERSION="${TAG}-dev-${COMMIT}"

OUTPUT="trace"
case "$(uname -s)" in MINGW*|MSYS*|CYGWIN*|Windows_NT) OUTPUT="trace.exe" ;; esac

go build -ldflags "-X github.com/GrayCodeAI/trace/cmd/trace/cli/versioninfo.Version=${VERSION} -X github.com/GrayCodeAI/trace/cmd/trace/cli/versioninfo.Commit=${COMMIT}" -o "$OUTPUT" ./cmd/trace
